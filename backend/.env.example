# Required: Financial Modeling Prep API Key
FMP_API_KEY=your_fmp_api_key

# Required: OpenAI API Key (for LLM narratives + SEC EDGAR embeddings)
OPENAI_API_KEY=your_openai_api_key

# Required for SEC EDGAR RAG: Postgres + pgvector connection string
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/goatlens

# Optional: Server configuration
PORT=8000

# Optional: Arize observability
ARIZE_API_KEY=your_arize_api_key
ARIZE_SPACE_ID=your_arize_space_id

# Optional: Telegram bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
